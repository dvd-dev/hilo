echo "Pre-installing Home Assistant component requirements..."
HA_VERSION=$(/home/vscode/.local/ha-venv/bin/python -c "import homeassistant.const; print(homeassistant.const.__version__)")
uv pip install --continue-on-error \
  -r "https://raw.githubusercontent.com/home-assistant/core/${HA_VERSION}/requirements_all.txt" || true

# Ensure critical packages that may have been skipped are installed
uv pip install \
  ha-ffmpeg \
  hassil \
  "PyTurboJPEG<2.0" \
  aiousbwatcher \
  aiodhcpwatcher \
  aiodiscover \
  async-upnp-client \
  radios \
  infrared-protocols \
  av \
  PyMetno \
  home-assistant-intents \
  mutagen \
  go2rtc-client \
  pymicro-vad \
  pyspeex-noise \
  pyserial \
  gTTS