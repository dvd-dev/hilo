#!/usr/bin/env bash
set -e
cd "$(dirname "$0")/.."

echo "Installing development dependencies..."
uv sync --group test

echo "Pre-installing Home Assistant component requirements..."
HA_VERSION=$(/home/vscode/.local/ha-venv/bin/python -c "import homeassistant.const; print(homeassistant.const.__version__)")
uv pip install --continue-on-error -r "https://raw.githubusercontent.com/home-assistant/core/${HA_VERSION}/requirements_all.txt" || true

echo "Installing known required packages..."
uv pip install \
  ha-ffmpeg \
  hassil \
  PyTurboJPEG \
  aiousbwatcher \
  aiodhcpwatcher \
  async-upnp-client \
  radios \
  infrared-protocols \
  av \
  PyMetno \
  home-assistant-intents

echo "Setup complete!"